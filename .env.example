# PostgreSQL connection string (cloud)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/azure_inbox_ops?schema=public"

# Redis queue backend
REDIS_URL="redis://localhost:6379"
TEST_MODE="false"
NEXT_PUBLIC_TEST_MODE="false"

# Microsoft Graph app credentials
