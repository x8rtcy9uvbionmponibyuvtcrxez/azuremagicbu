GRAPH_CLIENT_SECRET=""
GRAPH_TENANT_ID="common"
GRAPH_APP_ID=""
PS_SERVICE_URL="http://localhost:3099"
SMARTLEAD_API_KEY=""
INSTANTLY_API_KEY=""

# Cloudflare API credentials (Global API key auth)
CLOUDFLARE_API_KEY=""
CLOUDFLARE_EMAIL=""

# Optional legacy Cloudflare token fields
CLOUDFLARE_API_TOKEN=""
CLOUDFLARE_ACCOUNT_ID=""

# Base64 encoded 32-byte key used for encrypting secrets
ENCRYPTION_KEY=""
