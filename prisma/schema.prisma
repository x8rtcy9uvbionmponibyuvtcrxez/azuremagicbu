generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BatchStatus {
  uploading
  processing
  completed
  failed
}

enum TenantStatus {
  queued
  cloudflare
  tenant_prep
  auth_pending
  domain_add
  domain_verify
  licensed_user
  mailboxes
  mailbox_config
  dkim_config
  sequencer_connect
  completed
  failed
}

enum UploaderEsp {
  instantly
  smartlead
}

enum UploaderStatus {
  idle
  queued
  running
  completed
  failed
}

model Batch {
  id             String      @id @default(cuid())
  status         BatchStatus @default(uploading)
  totalCount     Int
  completedCount Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  // Per-batch uploader config (captured in the bulk upload UI).
  // Credentials are encrypted via lib/crypto.ts before persistence.
  // Absent/null means no auto-upload for this batch.
  uploaderEsp              UploaderEsp?
  uploaderAutoTrigger      Boolean      @default(false)
  uploaderWorkers          Int          @default(2)
  // Instantly-specific
  instantlyEmail           String?
  instantlyPassword        String?
  instantlyV1Key           String?
  instantlyV2Key           String?
  instantlyWorkspace       String?
  instantlyApiVersion      String?      @default("v1")
  // Smartlead-specific
  smartleadApiKey          String?
  smartleadLoginUrl        String?

  tenants Tenant[]
  events  TenantEvent[]
}

model Tenant {
  id                String       @id @default(cuid())
  batchId           String
  tenantName        String
  clientName        String       @default("Unknown")
  adminEmail        String
  adminPassword     String
  encryptionVersion Int          @default(1)
  domain            String
  inboxNames        String
  inboxCount        Int          @default(99)
  forwardingUrl     String
  status            TenantStatus @default(queued)
  progress          Int          @default(0)
  currentStep       String?
  zoneId            String?
  tenantId          String?
  authCode          String?
  deviceCode        String?
  authCodeExpiry    DateTime?
  authConfirmed     Boolean      @default(false)
  setupConfirmed    Boolean      @default(false)
  securityDefaultsDisabled Boolean @default(false)
  servicePrincipalCreated  Boolean @default(false)
  globalAdminAssigned      Boolean @default(false)
  // Phase 2: Domain setup
  domainAdded       Boolean      @default(false)
  domainVerified    Boolean      @default(false)
  domainDefault     Boolean      @default(false)
  dkimConfigured    Boolean      @default(false)
  licensedUserId    String?
  licensedUserUpn   String?
  // Phase 3: Mailbox setup
  sharedMailboxesCreated  Boolean  @default(false)
  passwordsSet            Boolean  @default(false)
  smtpAuthEnabled         Boolean  @default(false)
  delegationComplete      Boolean  @default(false)
  signInEnabled           Boolean  @default(false)
  cloudAppAdminAssigned   Boolean  @default(false)
  mailboxStatuses         String?
  // Phase 4: DKIM + sequencer integrations
  smartleadConnected      Boolean  @default(false)
  instantlyConnected      Boolean  @default(false)
  smartleadConnectedCount Int      @default(0)
  smartleadFailedCount    Int      @default(0)
  instantlyConnectedCount Int      @default(0)
  instantlyFailedCount    Int      @default(0)
  // Phase 4.5: Profile photos (applied via Graph PUT /users/{id}/photo/$value)
  // Operator uploads one photo per persona name (parsed from inboxNames),
  // worker matches Mailbox.displayName → personaName and PUTs the binary.
  // Auto-fires between mailbox creation and ESP upload when all personas
  // have photos; manual trigger always available.
  profilePhotosApplied    Boolean  @default(false)
  profilePhotosCompleted  Int?
  profilePhotosFailed     Int?
  csvUrl            String?
  errorMessage      String?
  // Phase 5: email-uploader tracking
  uploaderJobId          String?
  uploaderStatus         UploaderStatus @default(idle)
  uploaderQueuedAt       DateTime?
  uploaderStartedAt      DateTime?
  uploaderCompletedAt    DateTime?
  uploaderTotal          Int?
  uploaderSucceeded      Int?
  uploaderFailed         Int?
  uploaderSkipped        Int?
  uploaderWarnings       Int?
  uploaderErrorMessage   String?
  uploaderLastLogAt      DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  batch Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  events TenantEvent[]
  personas TenantPersona[]

  @@index([batchId, status])
  @@index([domain])
  @@index([uploaderStatus])
}

model TenantPersona {
  // One row per unique inboxName for a tenant. Holds the persona's profile
  // photo as raw bytes (Postgres BYTEA) plus apply state. The applyPhotos
  // worker matches Mailbox.displayName == personaName and PUTs photoData
  // to /users/{userId}/photo/$value via Microsoft Graph.
  id            String    @id @default(cuid())
  tenantId      String
  personaName   String
  photoData     Bytes?
  photoMime     String?
  photoSize     Int?
  photoApplied  Boolean   @default(false)
  applyError    String?
  appliedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, personaName])
  @@index([tenantId])
}

model TenantEvent {
  id        String   @id @default(cuid())
  batchId   String
  tenantId  String?
  level     String   @default("info")
  eventType String
  message   String
  details   String?
  createdAt DateTime @default(now())

  batch  Batch  @relation(fields: [batchId], references: [id], onDelete: Cascade)
  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([batchId, createdAt])
  @@index([tenantId, createdAt])
}

