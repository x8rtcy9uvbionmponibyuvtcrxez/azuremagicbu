generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BatchStatus {
  uploading
  processing
  completed
  failed
}

enum TenantStatus {
  queued
  cloudflare
  tenant_prep
  auth_pending
  domain_add
  domain_verify
  licensed_user
  mailboxes
  mailbox_config
  dkim_config
  sequencer_connect
  completed
  failed
}

model Batch {
  id             String      @id @default(cuid())
  status         BatchStatus @default(uploading)
  totalCount     Int
  completedCount Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  tenants Tenant[]
  events  TenantEvent[]
}

model Tenant {
  id                String       @id @default(cuid())
  batchId           String
  tenantName        String
  clientName        String       @default("Unknown")
  adminEmail        String
  adminPassword     String
  encryptionVersion Int          @default(1)
  domain            String
  inboxNames        String
  inboxCount        Int          @default(99)
  forwardingUrl     String
  status            TenantStatus @default(queued)
  progress          Int          @default(0)
  currentStep       String?
  zoneId            String?
  tenantId          String?
  authCode          String?
  deviceCode        String?
  authCodeExpiry    DateTime?
  authConfirmed     Boolean      @default(false)
  setupConfirmed    Boolean      @default(false)
  securityDefaultsDisabled Boolean @default(false)
  servicePrincipalCreated  Boolean @default(false)
  globalAdminAssigned      Boolean @default(false)
  // Phase 2: Domain setup
  domainAdded       Boolean      @default(false)
  domainVerified    Boolean      @default(false)
  domainDefault     Boolean      @default(false)
  dkimConfigured    Boolean      @default(false)
  licensedUserId    String?
  licensedUserUpn   String?
  // Phase 3: Mailbox setup
  sharedMailboxesCreated  Boolean  @default(false)
  passwordsSet            Boolean  @default(false)
  smtpAuthEnabled         Boolean  @default(false)
  delegationComplete      Boolean  @default(false)
  signInEnabled           Boolean  @default(false)
  cloudAppAdminAssigned   Boolean  @default(false)
  mailboxStatuses         String?
  // Phase 4: DKIM + sequencer integrations
  smartleadConnected      Boolean  @default(false)
  instantlyConnected      Boolean  @default(false)
  smartleadConnectedCount Int      @default(0)
  smartleadFailedCount    Int      @default(0)
  instantlyConnectedCount Int      @default(0)
  instantlyFailedCount    Int      @default(0)
  // Phase 5 (optional): email-uploader auto-trigger. Populated only when
  // EMAIL_UPLOADER_URL env var is set on the worker. The uploader runs
  // asynchronously — we store its job_id so the azure UI can link to its
  // live log view and (eventually) a polling loop can update upload status.
  uploaderJobId              String?
  uploaderStatus             String?   // queued | running | completed | failed
  uploaderTriggeredAt        DateTime?
  uploaderCompletedAt        DateTime?
  uploaderSucceededCount     Int      @default(0)
  uploaderFailedCount        Int      @default(0)
  csvUrl            String?
  errorMessage      String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  batch Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  events TenantEvent[]

  @@index([batchId, status])
  @@index([domain])
}

model TenantEvent {
  id        String   @id @default(cuid())
  batchId   String
  tenantId  String?
  level     String   @default("info")
  eventType String
  message   String
  details   String?
  createdAt DateTime @default(now())

  batch  Batch  @relation(fields: [batchId], references: [id], onDelete: Cascade)
  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([batchId, createdAt])
  @@index([tenantId, createdAt])
}

